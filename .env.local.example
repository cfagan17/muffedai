# Supabase - Get these from your Supabase project dashboard
# https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Anthropic API - Powers AI narratives and web research
# https://console.anthropic.com → API Keys
# Optional: Without this, reports use template-based narratives
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Resend - Email delivery for weekly reports
# https://resend.com → API Keys
# Optional: Without this, email delivery is skipped
RESEND_API_KEY=your-resend-api-key-here

# App URL - Used for email links
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron secret - Authenticates the weekly email cron endpoint
CRON_SECRET=your-cron-secret-here

# OpenAI - Powers text-to-speech audio briefings
# https://platform.openai.com → API Keys
# Optional: Without this, audio briefings are skipped
OPENAI_API_KEY=your-openai-api-key-here

# Supabase Service Role Key - Used for server-side storage uploads (audio files)
# https://app.supabase.com → Project Settings → API → service_role key
# Optional: Required only if OPENAI_API_KEY is set (for storing audio files)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# SportsDataIO - Injuries, projections, snap counts, season averages, rankings
# https://sportsdata.io/cart/free-trial/nfl (free trial, no credit card)
# Optional: Without this, reports skip injury/projection/ranking data
SPORTSDATA_API_KEY=your-sportsdata-api-key-here

# --- Data Sources ---
# Sleeper:      No API key needed — player stats and NFL state
# ESPN:         No API key needed — game scores, matchups, odds, headlines
# SportsDataIO: Requires SPORTSDATA_API_KEY — injuries, projections,
#               snap counts, season averages, position rankings, player news
# Web Research: Uses ANTHROPIC_API_KEY — game recaps, press conferences,
#               expert analysis via Claude web search
# Audio:        Requires OPENAI_API_KEY + SUPABASE_SERVICE_ROLE_KEY — TTS audio briefings
